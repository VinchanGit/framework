{
    "name": "vinchan/framework",
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "soft\\": "src/"
        },"files": [
            "src/Functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Vinchan",
            "email": "ademo@vip.qq.com"
        }
    ],
    "require": {
        "nikic/fast-route":"^1.3",
        "symfony/console": "^5.4"
    },
    "require-dev": {
        "swoole/ide-helper": "^4.5",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpunit/phpunit": "^9.5",
        "symfony/var-dumper": "^5.4",
        "psr/container": "^1.1",
        "psr/http-server-middleware": "^1.0"
    },
    "scripts": {
        "start": "php ./bin.php start",
        "dev": "php ./bin.php",
        "cs-fix": "./vendor/bin/php-cs-fixer fix",
        "test": "php ./vendor/bin/phpunit"
    }
}
